{
  "name": "@tomehq/cli",
  "version": "0.8.1",
  "description": "Tome documentation platform CLI",
  "type": "module",
  "bin": {
    "tome": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsdown src/cli.ts src/index.ts --format esm --dts",
    "dev": "tsdown src/cli.ts src/index.ts --format esm --dts --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tomehq/core": "workspace:*",
    "@vitejs/plugin-react": "catalog:",
    "commander": "^14.0.0",
    "picocolors": "^1.1.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vite": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomehq/tome.git",
    "directory": "packages/cli"
  }
}
